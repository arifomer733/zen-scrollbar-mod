{
    "manifest_version": 2,
    "name": "Zen Scrollbar Mod",
    "version": "1.0",
    "description": "Minimal scrollbar control for Zen Browser",
    "permissions": [
        "tabs",
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },
    "browser_action": {
        "default_title": "Toggle Scrollbar Mod"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "zen-scrollbar-mod@example.com",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}